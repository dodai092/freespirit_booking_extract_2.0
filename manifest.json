{
  "manifest_version": 3,
  "name": "Reviews Extract",
  "version": "1.0",
  "description": "Extracts and reformats reviews from reviewing platforms.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite" 
  ],
  "host_permissions": [
    "https://script.google.com/",
    "https://script.googleusercontent.com/"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Reviews Extract",
    "default_icon": "logo.png"
  },
  "icons": {
    "48": "logo.png",
    "128": "logo.png"
  }
}